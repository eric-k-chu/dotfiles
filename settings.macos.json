{
  "[markdown]": {
    "editor.formatOnSave": true
  },
  "[mdx]": {
    "editor.codeActionsOnSave": {
      "source.addMissingImports.ts": "never",
      "source.fixAll.eslint": "never",
      "source.organizeImports": "never",
      "source.removeUnusedImports": "never"
    },
    "editor.formatOnSave": true
  },
  "[typescript]": {
    "editor.codeActionsOnSave": {
      "source.fixAll.ts": "never",
      "source.organizeImports": "never",
      "source.removeUnusedImports": "always"
    },
    "editor.formatOnSave": true
  },
  "[typescriptreact]": {
    "editor.codeActionsOnSave": {
      "source.fixAll.ts": "never",
      "source.organizeImports": "never",
      "source.removeUnusedImports": "always"
    },
    "editor.formatOnSave": true
  },
  "editor.codeLens": false,
  "editor.cursorBlinking": "solid",
  "editor.cursorStyle": "line",
  "editor.defaultFormatter": "esbenp.prettier-vscode",
  // "editor.fontFamily": "CaskaydiaCove Nerd Font",
  "editor.fontFamily": "JetBrains Mono NL",
  "editor.fontSize": 14,
  "editor.lineHeight": 1.6,
  "editor.glyphMargin": false,
  "editor.guides.indentation": false,
  "editor.minimap.enabled": false,
  "editor.scrollbar.vertical": "visible",
  "editor.stickyScroll.enabled": false,
  "editor.tabSize": 2,
  "explorer.compactFolders": false,
  "files.exclude": {
    "**/.DS_Store": true,
    "**/.git": true,
    "**/.hg": true,
    "**/.svn": true,
    "**/CVS": true,
    "**/Thumbs.db": true,
    "**/build": true,
    "**/dist": true,
    "**/node_modules/": true,
    "*/node_modules/": true,
    "node_modules/": true
  },
  "files.restoreUndoStack": false,
  "git.autorefresh": true,
  "template-string-converter.autoRemoveTemplateString": true,
  "template-string-converter.enabled": true,
  "template-string-converter.quoteType": "both",
  "template-string-converter.validLanguages": [
    "typescript",
    "javascript",
    "typescriptreact",
    "javascriptreact"
  ],
  "terminal.integrated.fontSize": 14,
  "terminal.integrated.shellIntegration.enabled": false,
  "typescript.implementationsCodeLens.enabled": false,
  "typescript.preferences.autoImportFileExcludePatterns": [
    "**/dist/",
    "**/build/",
  ],
  "typescript.format.semicolons": "remove",
  "typescript.preferences.quoteStyle": "single",
  "typescript.referencesCodeLens.enabled": false,
  "typescript.updateImportsOnFileMove.enabled": "never",
  "typescript.preferGoToSourceDefinition": true,
  "typescript.tsserver.watchOptions": "vscode",
  "window.commandCenter": false,
  "window.title": "${activeEditorMedium}",
  "window.titleBarStyle": "custom",
  "workbench.activityBar.location": "top",
  "workbench.colorTheme": "Catppuccin Macchiato",
  "workbench.editor.restoreViewState": false,
  "workbench.iconTheme": "eq-material-theme-icons-light",
  "workbench.layoutControl.enabled": false,
  "workbench.settings.applyToAllProfiles": [],
  "workbench.settings.editor": "json",
  "workbench.tree.enableStickyScroll": false,
  "workbench.tree.indent": 20,
  "workbench.sideBar.location": "right",
  "editor.lineNumbers": "relative",
  "files.watcherExclude": {
    "**/.git/objects/**": true,
    "**/.git/subtree-cache/**": true,
    "**/.hg/store/**": true,
    "**/node_modules/**": true,
    "**/build/**": true,
  },
}
